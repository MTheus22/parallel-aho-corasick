# Build artifacts
build/
*.o
*.d
*.a
*.so
*.dSYM/

# Sanitizer / debugger outputs
core
core.*
vgcore.*
*.gcno
*.gcda
*.gcov

# Profiling output (perf, gprof, vtune, callgrind)
perf.data*
gmon.out
callgrind.out.*
*.qdrep
*.qdstrm

# Raw downloaded data files (recreated by scripts/)
rules/
*.rules
*.tar.gz
*.tar.bz2
*.xml.bz2
data/*

# Keep this README versioned (pattern lists are generated by scripts/)
!data/README.md

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.DS_Store

# Language server / clangd
.cache/
.clangd/
compile_commands.json

# Python bytecode (scripts/)
__pycache__/
*.pyc

# Ignora o conteúdo de runs/ (logs grandes, regeneráveis), MAS deixa o
# diretório re-incluível abaixo. Usa runs/* (não runs/) porque o git não
# consegue re-incluir um caminho cujo diretório-pai foi excluído.
runs/*
# Exceção: os resultados dos sweeps SÃO versionados (logs/env/sweep.db pequenos,
# ~1,5 MB cada, e irreproduzíveis — corridas pontuais). Os dados de corpus/padrões
# continuam ignorados por estarem em data/.
#  - runs/workstation/      : portabilidade (Ryzen 9 9950X)
#  - runs/i5/               : fonte de verdade do TCC (i5, 2026-05-29)
#  - runs/i5_2026-06-28/    : 2º run do i5 (headless, não-canônico)
!runs/workstation/
!runs/i5/
!runs/i5_2026-06-28/
# Sweep run logs (regenerated by scripts/run_*_sweep.sh)
*_sweep.log
i5.out
run_all.out
workstation.out
